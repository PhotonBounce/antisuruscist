# ── Polygon Amoy Testnet Deploy Config ──────────────────────────────────────
# Copy this file to  .env  and fill in your values (NEVER commit .env to git!)

# Your wallet private key — NEVER share this
# Export from MetaMask: Account Details → Export Private Key
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Amoy Testnet RPC — public endpoint (or use your own from Alchemy/Infura)
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Base URI for token metadata (can be changed later via setBaseURI if you add it)
BASE_TOKEN_URI=https://anti-ruscist.xyz/nft/metadata/

# ── To get free Amoy MATIC for gas fees ──────────────────────────────────────
# 1. Go to https://faucet.polygon.technology
# 2. Select "Polygon Amoy" testnet
# 3. Connect your wallet and request 0.5 MATIC
#    (enough to deploy the contract + hundreds of mints)
